<Window x:Class="Clockwork.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Clockwork"
        xmlns:loc="clr-namespace:Clockwork.I18n"
        mc:Ignorable="d"
        Title="Clockwork" Height="660" Width="1040" MinHeight="520" MinWidth="820"
        Background="{StaticResource BrushInk}"
        Icon="/logo.ico" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="DelayCol" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="Foreground" Value="{StaticResource BrushMuted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- 系统启动项单元格：列宽有限、内容常被截断（长路径 / 范围「所有用户（需管理员）」等）。
             省略号收尾 + 始终挂 tooltip=本单元格全文，hover 即可看全，不丢信息。 -->
        <Style x:Key="SysCell" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
        </Style>
        <Style x:Key="SysCmdCell" TargetType="TextBlock" BasedOn="{StaticResource DelayCol}">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
        </Style>
        <Style x:Key="KindChipCell" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushSteel}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Grid>
        <TabControl x:Name="Tabs" Margin="8,4,8,6">
            <!-- ===== 启动清单 ===== -->
            <TabItem x:Name="TabLaunch" Header="{loc:Loc Tab_Launch}">
                <Grid Margin="2,10,2,2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="168"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource ListPanel}">
                        <DataGrid x:Name="GridLaunch" AutoGenerateColumns="False" CanUserAddRows="False"
                                  CanUserDeleteRows="False" SelectionMode="Single" MouseDoubleClick="GridLaunch_DoubleClick">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="24" CanUserResize="False" CellTemplate="{StaticResource RailCell}" CellStyle="{StaticResource RailCellStyle}"/>
                                <DataGridTemplateColumn Header="{loc:Loc Col_Enabled}" Width="52">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="{loc:Loc Col_Kind}" Width="Auto" MinWidth="104">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource KindChipCell}">
                                                <TextBlock Text="{Binding KindLabel}" Style="{StaticResource KindChip}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="{loc:Loc Col_Summary}" Binding="{Binding Summary}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="{loc:Loc Col_Delay}" Binding="{Binding DelayText}" Width="80" IsReadOnly="True"
                                                    ElementStyle="{StaticResource DelayCol}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        </Border>
                        <DockPanel Grid.Column="1" Margin="14,0,0,0">
                            <Grid DockPanel.Dock="Bottom" Margin="2,14,0,2">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="2" Background="{StaticResource BrushLine}" Margin="0,1,9,1"/>
                                <TextBlock Grid.Column="1" Text="{loc:Loc Launch_Hint}" Style="{StaticResource Hint}" TextWrapping="Wrap"/>
                            </Grid>
                            <StackPanel>
                            <TextBlock Text="{loc:Loc Tab_Launch}" Style="{StaticResource GroupLabel}" Margin="2,0,0,4"/>
                            <Button x:Name="LAdd" Content="{loc:Loc Btn_AddMenu}" Style="{StaticResource PrimaryButton}" Margin="0,3" Click="LAdd_Click"/>
                            <Button x:Name="LEdit" Content="{loc:Loc Btn_Edit}" Margin="0,3" Click="LEdit_Click"/>
                            <Button x:Name="LDel" Content="{loc:Loc Btn_Delete}" Style="{StaticResource DangerButton}" Margin="0,3" Click="LDel_Click"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Button x:Name="LUp" Grid.Column="0" Content="{loc:Loc Btn_Up}" Margin="0,0,3,0" Click="LUp_Click"/>
                                <Button x:Name="LDown" Grid.Column="1" Content="{loc:Loc Btn_Down}" Margin="3,0,0,0" Click="LDown_Click"/>
                            </Grid>
                            <Button x:Name="LRun" Content="{loc:Loc Btn_RunStep}" Style="{StaticResource RunButton}" Margin="0,10,0,2" Click="LRun_Click"/>
                            </StackPanel>
                        </DockPanel>
                </Grid>
            </TabItem>

            <!-- ===== 定时提醒 ===== -->
            <TabItem Header="{loc:Loc Tab_Reminder}">
                <Grid Margin="2,10,2,2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="168"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource ListPanel}">
                        <DataGrid x:Name="GridRemind" AutoGenerateColumns="False" CanUserAddRows="False"
                                  CanUserDeleteRows="False" SelectionMode="Single" MouseDoubleClick="GridRemind_DoubleClick">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="{loc:Loc Col_Enabled}" Width="52">
                                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                                        <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate></DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="{loc:Loc Col_Time}" Binding="{Binding TimeLabel}" Width="Auto" MinWidth="140" IsReadOnly="True" ElementStyle="{StaticResource DelayCol}"/>
                                <DataGridTextColumn Header="{loc:Loc Col_Period}" Binding="{Binding PeriodLabel}" Width="Auto" MinWidth="120" IsReadOnly="True"/>
                                <DataGridTextColumn Header="{loc:Loc Col_Text}" Binding="{Binding Text}" Width="*" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="{loc:Loc Col_Speak}" Width="56">
                                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                                        <CheckBox IsChecked="{Binding Speak, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate></DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        </Border>
                        <DockPanel Grid.Column="1" Margin="14,0,0,0">
                            <Grid DockPanel.Dock="Bottom" Margin="2,14,0,2">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="2" Background="{StaticResource BrushLine}" Margin="0,1,9,1"/>
                                <TextBlock Grid.Column="1" Text="{loc:Loc Reminder_Hint}" Style="{StaticResource Hint}" TextWrapping="Wrap"/>
                            </Grid>
                            <StackPanel>
                            <TextBlock Text="{loc:Loc Tab_Reminder}" Style="{StaticResource GroupLabel}" Margin="2,0,0,4"/>
                            <Button x:Name="RAdd" Content="{loc:Loc Btn_Add}" Style="{StaticResource PrimaryButton}" Margin="0,3" Click="RAdd_Click"/>
                            <Button x:Name="REdit" Content="{loc:Loc Btn_Edit}" Margin="0,3" Click="REdit_Click"/>
                            <Button x:Name="RDel" Content="{loc:Loc Btn_Delete}" Style="{StaticResource DangerButton}" Margin="0,3" Click="RDel_Click"/>
                            <Button x:Name="RPreview" Content="{loc:Loc Btn_Preview}" Style="{StaticResource RunButton}" Margin="0,10,0,2" Click="RPreview_Click"/>
                            </StackPanel>
                        </DockPanel>
                </Grid>
            </TabItem>

            <!-- ===== 动作组 ===== -->
            <TabItem Header="{loc:Loc Tab_Group}">
                <Grid Margin="2,10,2,2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="168"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource ListPanel}">
                        <DataGrid x:Name="GridGroup" AutoGenerateColumns="False" CanUserAddRows="False"
                                  CanUserDeleteRows="False" SelectionMode="Single" MouseDoubleClick="GridGroup_DoubleClick">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="{loc:Loc Col_Enabled}" Width="52">
                                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                                        <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate></DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="{loc:Loc Col_Name}" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="{loc:Loc Col_Steps}" Binding="{Binding StepCount}" Width="72" IsReadOnly="True" ElementStyle="{StaticResource DelayCol}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        </Border>
                        <DockPanel Grid.Column="1" Margin="14,0,0,0">
                            <Grid DockPanel.Dock="Bottom" Margin="2,14,0,2">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="2" Background="{StaticResource BrushLine}" Margin="0,1,9,1"/>
                                <TextBlock Grid.Column="1" Text="{loc:Loc Group_Hint}" Style="{StaticResource Hint}" TextWrapping="Wrap"/>
                            </Grid>
                            <StackPanel>
                            <TextBlock Text="{loc:Loc Tab_Group}" Style="{StaticResource GroupLabel}" Margin="2,0,0,4"/>
                            <Button x:Name="GAdd" Content="{loc:Loc Btn_AddMenu}" Style="{StaticResource PrimaryButton}" Margin="0,3" Click="GAdd_Click"/>
                            <Button x:Name="GEdit" Content="{loc:Loc Btn_Edit}" Margin="0,3" Click="GEdit_Click"/>
                            <Button x:Name="GDel" Content="{loc:Loc Btn_Delete}" Style="{StaticResource DangerButton}" Margin="0,3" Click="GDel_Click"/>
                            <Button x:Name="GRun" Content="{loc:Loc Btn_RunGroup}" Style="{StaticResource RunButton}" Margin="0,10,0,2" Click="GRun_Click"/>
                            </StackPanel>
                        </DockPanel>
                </Grid>
            </TabItem>

            <!-- ===== 系统启动项 ===== -->
            <TabItem x:Name="TabSystem" Header="{loc:Loc Tab_System}">
                <Grid Margin="2,10,2,2">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock Text="{loc:Loc System_Filter}" Style="{StaticResource Hint}" VerticalAlignment="Center" FontSize="13" Margin="2,0,10,0"/>
                            <TextBox x:Name="SSearch" Width="320" Height="30" VerticalContentAlignment="Center" TextChanged="SSearch_TextChanged"/>
                        </StackPanel>
                        <CheckBox x:Name="ShowReadOnly" Content="{loc:Loc System_ShowReadOnly}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  FontSize="12.5" Checked="ShowReadOnly_Changed" Unchecked="ShowReadOnly_Changed"/>
                    </Grid>
                    <Border Grid.Row="1" Margin="0,10,0,0" Style="{StaticResource ListPanel}">
                    <DataGrid x:Name="GridSystem" AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserDeleteRows="False" SelectionMode="Single" PreviewMouseRightButtonDown="GridSystem_RightClick">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{loc:Loc Sys_Takeover}" Click="SysTakeOver_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="{loc:Loc Col_Enabled}" Width="52">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate>
                                    <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEdit}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{loc:Loc Col_Name}" Binding="{Binding Name}" Width="170" IsReadOnly="True" ElementStyle="{StaticResource SysCell}"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Command}" Binding="{Binding Command}" Width="*" IsReadOnly="True"
                                                ElementStyle="{StaticResource SysCmdCell}"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Source}" Binding="{Binding SourceLabel}" Width="Auto" MinWidth="140" IsReadOnly="True" ElementStyle="{StaticResource SysCell}"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Scope}" Binding="{Binding ScopeLabel}" Width="Auto" MinWidth="172" IsReadOnly="True" ElementStyle="{StaticResource SysCell}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    </Border>
                    <TextBlock x:Name="SysLoading" Grid.Row="1" Text="{loc:Loc System_Scanning}" Style="{StaticResource Hint}" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="SRefresh" Content="{loc:Loc System_Refresh}" Click="SRefresh_Click"/>
                        <TextBlock Text="{loc:Loc System_Footer}" Style="{StaticResource Hint}"
                                   VerticalAlignment="Center" Margin="14,0,0,0" TextWrapping="Wrap" MaxWidth="1000"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ===== 设置 ===== -->
            <TabItem Header="{loc:Loc Tab_Settings}">
                <!-- 整块面板铺满设置页：两栏(常规 | 关于) + 右下氛围擒纵轮。整页变成一块蓝钢仪表盘，
                     不再是几张小卡片浮在暗色空地上；随窗口拉伸，天生自适应。 -->
                <Border Style="{StaticResource Card}" Margin="8,8,8,6" Padding="0" ClipToBounds="True">
                    <Grid>
                        <!-- 氛围擒纵轮：黄铜低透明、右下溢出，把稀疏处填成品牌纹理而非空地 -->
                        <Path Fill="{StaticResource BrushBrass}" Opacity="0.06" Stretch="Uniform" Width="480" Height="480"
                              HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-80,-110" IsHitTestVisible="False"
                              Data="F0 M128,36 L128,24 L156.43,40.5 L160.14,29.09 L182.08,53.57 L189.13,43.86 L202.43,73.92 L212.14,66.87 L215.5,99.57 L226.91,95.86 L220,128 L232,128 L215.5,156.43 L226.91,160.14 L202.43,182.08 L212.14,189.13 L182.08,202.43 L189.13,212.14 L156.43,215.5 L160.14,226.91 L128,220 L128,232 L99.57,215.5 L95.86,226.91 L73.92,202.43 L66.87,212.14 L53.57,182.08 L43.86,189.13 L40.5,156.43 L29.09,160.14 L36,128 L24,128 L40.5,99.57 L29.09,95.86 L53.57,73.92 L43.86,66.87 L73.92,53.57 L66.87,43.86 L99.57,40.5 L95.86,29.09 Z M192,128 A64,64 0 1 0 64,128 A64,64 0 1 0 192,128Z"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.3*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ===== 左：常规 ===== -->
                            <StackPanel Grid.Column="0" Margin="28,26,28,26" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                                    <Border Width="3" Height="16" Background="{StaticResource BrushBrass}" CornerRadius="1.5" VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:Loc Settings_General}" FontFamily="{StaticResource FontDisplay}" FontWeight="SemiBold" FontSize="15" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- 开机延迟 -->
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="112"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Loc Settings_StartupDelay}" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Grid.Column="1" x:Name="StartupDelayBox" Width="80" Height="30" HorizontalAlignment="Left" VerticalContentAlignment="Center" LostFocus="Settings_Changed"/>
                                </Grid>

                                <!-- 启动时最小化 -->
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="112"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="1" x:Name="StartMinChk" Content="{loc:Loc Settings_StartMinimized}" VerticalAlignment="Center" Click="Settings_Changed"/>
                                </Grid>

                                <!-- 急停键（按键捕捉） -->
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="112"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Loc Settings_StopHotkey}" Style="{StaticResource FieldLabel}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBox x:Name="HotkeyBox" Width="190" Height="32" HorizontalAlignment="Left" Style="{StaticResource HotkeyCapture}"
                                                 GotKeyboardFocus="Hotkey_GotFocus" LostKeyboardFocus="Hotkey_LostFocus" PreviewKeyDown="Hotkey_PreviewKeyDown"/>
                                        <TextBlock Text="{loc:Loc Settings_HotkeyCaptureTip}" Style="{StaticResource Hint}" Margin="0,6,0,0" TextWrapping="Wrap" MaxWidth="380"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 语言 -->
                                <Grid Margin="0,10,0,5">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="112"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Loc Settings_Language}" Style="{StaticResource FieldLabel}"/>
                                    <StackPanel Grid.Column="1">
                                        <ComboBox x:Name="LangCombo" Width="170" Height="30" HorizontalAlignment="Left" SelectionChanged="Lang_Changed"/>
                                        <TextBlock Text="{loc:Loc Settings_LangRestart}" Style="{StaticResource Hint}" Margin="0,6,0,0" TextWrapping="Wrap" MaxWidth="380"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 开机自启 -->
                                <Grid Margin="0,14,0,2">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="112"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Button Grid.Column="1" x:Name="AutostartBtn" Content="{loc:Loc Autostart_Checking}" HorizontalAlignment="Left" Click="Autostart_Click"/>
                                </Grid>
                            </StackPanel>

                            <!-- 竖分隔 -->
                            <Border Grid.Column="1" Width="1" Background="{StaticResource BrushLine}" Margin="0,26"/>

                            <!-- ===== 右：关于 ===== -->
                            <StackPanel Grid.Column="2" Margin="32,26,28,26" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Border Width="3" Height="16" Background="{StaticResource BrushBrass}" CornerRadius="1.5" VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:Loc Settings_About}" FontFamily="{StaticResource FontDisplay}" FontWeight="SemiBold" FontSize="15" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,20,0,16">
                                    <Image Source="/logo-256.png" Width="60" Height="60" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Clockwork" FontFamily="{StaticResource FontDisplay}" FontSize="25" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="VersionText" Foreground="{StaticResource BrushMuted}" FontFamily="{StaticResource FontMono}" FontSize="13" VerticalAlignment="Bottom" Margin="10,0,0,4"/>
                                        </StackPanel>
                                        <TextBlock Text="{loc:Loc App_Subtitle}" Foreground="{StaticResource BrushMuted}" FontSize="13" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,18">
                                    <Button Content="GitHub" Click="GitHub_Click" Margin="0,0,10,0"/>
                                    <Button x:Name="CheckUpdateBtn" Content="{loc:Loc About_CheckUpdate}" Style="{StaticResource RunButton}" Click="CheckUpdate_Click"/>
                                </StackPanel>
                                <TextBlock Text="365 开源计划 · #020" Style="{StaticResource Hint}" FontFamily="{StaticResource FontMono}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
