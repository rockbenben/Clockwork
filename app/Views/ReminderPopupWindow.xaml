<Window x:Class="Clockwork.Views.ReminderPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clockwork" Width="460" SizeToContent="Height" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True" ResizeMode="NoResize">
    <!-- 无系统标题栏的品牌卡片（避免 OS 标题与内部眉标重复）：左侧黄铜签名轨 + 品牌标记/眉标头 + 正文 + 操作按钮。
         整块蓝钢面板，弹出时读作"来自 Clockwork 的提醒"。Esc 取消。 -->
    <Border Background="{StaticResource BrushSlate}" BorderBrush="{StaticResource BrushLine}" BorderThickness="1"
            CornerRadius="12" Margin="12" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#0A0D12" BlurRadius="22" ShadowDepth="5" Direction="270" Opacity="0.55"/>
        </Border.Effect>
        <Grid>
            <Border Width="3" Background="{StaticResource BrushBrass}" HorizontalAlignment="Left"/>
            <Grid Margin="26,22,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 头：品牌标记 + 眉标 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                    <Image Source="/logo-256.png" Width="20" Height="20" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock x:Name="Eyebrow" FontFamily="{StaticResource FontMono}" FontSize="12"
                               Foreground="{StaticResource BrushBrass}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <!-- 提醒正文 -->
                <TextBlock Grid.Row="1" x:Name="MsgText" TextWrapping="Wrap" FontSize="16.5"
                           Foreground="{StaticResource BrushPaper}" LineStackingStrategy="BlockLineHeight"
                           LineHeight="25" Margin="0,0,0,22"/>

                <!-- 操作按钮 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="YesBtn" Style="{StaticResource PrimaryButton}" MinWidth="72" Height="34" Margin="0,0,8,0" Click="Yes_Click"/>
                    <Button x:Name="NoBtn" MinWidth="72" Height="34" Margin="0,0,8,0" Click="No_Click"/>
                    <Button x:Name="OkBtn" Style="{StaticResource PrimaryButton}" MinWidth="72" Height="34" Margin="0,0,8,0" Click="Ok_Click"/>
                    <Button x:Name="SnoozeBtn" MinWidth="104" Height="34" Margin="0,0,4,0" Click="Snooze_Click"/>
                    <Button x:Name="SnoozeMoreBtn" Content="▾" Width="30" Height="34" Click="SnoozeMore_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
