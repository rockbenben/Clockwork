<Window x:Class="Clockwork.Views.ReminderEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Clockwork.I18n"
        Title="{loc:Loc Ed_Title_Reminder}" Width="600" SizeToContent="Height" MaxHeight="840" WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushInk}"
        ShowInTaskbar="False" MinWidth="520" MinHeight="520">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,3"><TextBlock Text="{loc:Loc Ed_Trigger}" Width="90" TextAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/><ComboBox x:Name="TrigCombo" Width="200" Height="28" SelectionChanged="Trig_Changed"/></StackPanel>

                <StackPanel x:Name="TimeRow" Orientation="Horizontal" Margin="0,3"><TextBlock Text="{loc:Loc Ed_Time}" Width="90" TextAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/><TextBox x:Name="TimeBox" Width="100" Height="28"/></StackPanel>

                <StackPanel x:Name="StartupRow" Margin="0,3">
                    <StackPanel Orientation="Horizontal"><TextBlock Text="{loc:Loc Ed_LoginTiming}" Width="90" TextAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/><ComboBox x:Name="SModeCombo" Width="130" Height="28" SelectionChanged="SMode_Changed"/>
                        <TextBox x:Name="SHourBox" Width="50" Height="28" Margin="8,0,4,0"/><TextBlock x:Name="SHourLbl" Text="{loc:Loc Ed_Hour}" VerticalAlignment="Center"/></StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="100,4,0,0"><TextBlock Text="{loc:Loc Ed_OnlyBoot}" VerticalAlignment="Center"/><TextBox x:Name="SWithinBox" Width="50" Height="26" Margin="6,0"/><TextBlock Text="{loc:Loc Ed_WithinHint}" Foreground="{StaticResource BrushMuted}" FontSize="12" VerticalAlignment="Center"/></StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,3"><TextBlock Text="{loc:Loc Ed_Period}" Width="90" TextAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/><ComboBox x:Name="RecurCombo" Width="160" Height="28" SelectionChanged="Recur_Changed"/></StackPanel>

                <StackPanel x:Name="DaysRow" Orientation="Horizontal" Margin="100,3,0,3">
                    <CheckBox x:Name="Day1" Content="{loc:Loc Day_1}" Margin="0,0,10,0"/><CheckBox x:Name="Day2" Content="{loc:Loc Day_2}" Margin="0,0,10,0"/><CheckBox x:Name="Day3" Content="{loc:Loc Day_3}" Margin="0,0,10,0"/>
                    <CheckBox x:Name="Day4" Content="{loc:Loc Day_4}" Margin="0,0,10,0"/><CheckBox x:Name="Day5" Content="{loc:Loc Day_5}" Margin="0,0,10,0"/><CheckBox x:Name="Day6" Content="{loc:Loc Day_6}" Margin="0,0,10,0"/><CheckBox x:Name="Day7" Content="{loc:Loc Day_7}" Margin="0,0,10,0"/>
                </StackPanel>
                <StackPanel x:Name="IntervalRow" Orientation="Horizontal" Margin="0,3"><TextBlock Text="{loc:Loc Ed_EveryNDays}" Width="90" TextAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/><TextBox x:Name="IntervalBox" Width="60" Height="28"/><TextBlock Text="{loc:Loc Ed_AnchorDays}" VerticalAlignment="Center" Margin="6,0"/><TextBox x:Name="AnchorBox" Width="110" Height="28"/><Button Content="{loc:Loc Btn_PickDate}" Width="66" Height="28" Margin="6,0,0,0" Click="PickAnchor_Click"/><TextBlock Text="{loc:Loc Ed_AnchorHint}" Foreground="{StaticResource BrushMuted}" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
                <StackPanel x:Name="MonthlyRow" Orientation="Horizontal" Margin="0,3"><TextBlock Text="{loc:Loc Ed_MonthlyDay}" Width="90" TextAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/><TextBox x:Name="MonthlyBox" Width="60" Height="28"/></StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,3"><TextBlock Text="{loc:Loc Ed_Text}" Width="90" TextAlignment="Right" Margin="0,4,10,0" VerticalAlignment="Top"/><TextBox x:Name="MsgBox" Width="420" Height="72" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/></StackPanel>
                <CheckBox x:Name="SpeakChk" Content="{loc:Loc Ed_Speak}" Margin="100,3,0,3"/>

                <StackPanel Orientation="Horizontal" Margin="0,3"><TextBlock Text="{loc:Loc Ed_SilentGroup}" Width="90" TextAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/><ComboBox x:Name="SilentCombo" Width="240" Height="28"/></StackPanel>
                <TextBlock Text="{loc:Loc Ed_SilentHint}" Foreground="{StaticResource BrushMuted}" FontSize="12" Margin="100,0,0,6" TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal" Margin="0,3"><TextBlock Text="{loc:Loc Ed_OnYes}" Width="90" TextAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/><ComboBox x:Name="OnYesTypeCombo" Width="140" Height="28" SelectionChanged="OnYesType_Changed"/>
                    <TextBox x:Name="OnYesTargetBox" Width="150" Height="28" Margin="8,0,0,0"/><Button x:Name="OnYesBrowseBtn" Content="{loc:Loc Btn_Browse}" Width="66" Height="28" Margin="6,0,0,0" Click="BrowseOnYes_Click"/><ComboBox x:Name="OnYesGroupCombo" Width="220" Height="28" Margin="8,0,0,0"/></StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,3"><TextBlock Text="{loc:Loc Ed_AutoDismiss}" Width="90" TextAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/><TextBox x:Name="AutoBox" Width="60" Height="28"/><TextBlock Text="{loc:Loc Ed_AutoHint}" Foreground="{StaticResource BrushMuted}" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/></StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,3"><TextBlock Text="{loc:Loc Ed_RepeatNag}" Width="90" TextAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/><TextBox x:Name="RepeatBox" Width="60" Height="28"/><TextBlock Text="{loc:Loc Ed_RepeatUntilPre}" VerticalAlignment="Center" Margin="6,0"/><TextBox x:Name="RepeatUntilBox" Width="70" Height="28"/><TextBlock Text="{loc:Loc Ed_RepeatUntilHint}" Foreground="{StaticResource BrushMuted}" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,3"><TextBlock Text="{loc:Loc Ed_TrigDelay}" Width="90" TextAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/><TextBox x:Name="DelayBox" Width="60" Height="28"/><TextBlock Text="{loc:Loc Ed_DelaySecPlus}" VerticalAlignment="Center" Margin="6,0"/><TextBox x:Name="RandomBox" Width="60" Height="28"/><TextBlock Text="{loc:Loc Ed_Sec}" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
                <StackPanel x:Name="GraceRow" Orientation="Horizontal" Margin="0,3"><TextBlock Text="{loc:Loc Ed_Grace}" Width="90" TextAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/><TextBox x:Name="GraceBox" Width="60" Height="28"/><TextBlock Text="{loc:Loc Ed_GraceHint}" Foreground="{StaticResource BrushMuted}" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/></StackPanel>
                <StackPanel x:Name="CatchUpRow" Orientation="Horizontal" Margin="0,3"><TextBlock Width="90" Margin="0,0,10,0"/><CheckBox x:Name="CatchUpChk" Content="{loc:Loc Ed_CatchUp}" VerticalAlignment="Center"/></StackPanel>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{loc:Loc Ed_Ok}" Style="{StaticResource PrimaryButton}" MinWidth="80" Height="32" Margin="0,0,10,0" Click="Ok_Click" IsDefault="True"/>
            <Button Content="{loc:Loc Ed_Cancel}" MinWidth="70" Height="32" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
