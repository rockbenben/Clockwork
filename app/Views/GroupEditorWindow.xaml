<Window x:Class="Clockwork.Views.GroupEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Clockwork.I18n"
        Title="{loc:Loc Ed_Title_Group}" Width="720" Height="580" WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushInk}"
        ShowInTaskbar="False" MinWidth="600" MinHeight="460">
    <Grid Margin="18,16,18,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 名称 + 热键 -->
            <RowDefinition Height="Auto"/>   <!-- 说明 -->
            <RowDefinition Height="Auto"/>   <!-- 「步骤」小标题 + 添加 -->
            <RowDefinition Height="*"/>      <!-- 步骤序列（主体）-->
            <RowDefinition Height="Auto"/>   <!-- 确定 / 取消 -->
        </Grid.RowDefinitions>

        <!-- ===== 表头：名称 + 全局热键 ===== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Loc Col_Name}" Style="{StaticResource FieldLabel}"/>
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="NameBox" Height="30" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Loc Ed_GroupHotkey}" Style="{StaticResource FieldLabel}"/>
            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                <TextBox x:Name="HotkeyBox" Width="170" Height="30" Style="{StaticResource HotkeyCapture}"/>
                <TextBlock Text="{loc:Loc Ed_GroupHotkeyHint}" Style="{StaticResource Hint}" VerticalAlignment="Center"
                           Margin="12,0,0,0" TextWrapping="Wrap" MaxWidth="340"/>
            </StackPanel>
        </Grid>

        <!-- 动作组只定义动作，触发在别处引用 -->
        <TextBlock Grid.Row="1" Text="{loc:Loc Ed_GroupHint}" Style="{StaticResource Hint}" FontSize="11.5" Margin="0,10,0,0"/>

        <!-- ===== 「步骤」小标题（刻字面板标签）+ 添加按钮 ===== -->
        <Grid Grid.Row="2" Margin="0,16,0,6">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{loc:Loc Col_Steps}" Style="{StaticResource GroupLabel}" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
            <Button Grid.Column="1" x:Name="SAdd" Content="{loc:Loc Btn_AddMenu}" Style="{StaticResource PrimaryButton}"
                    Height="30" Padding="16,0" Click="SAdd_Click"/>
        </Grid>

        <!-- ===== 步骤序列：黄铜轨 · 类型徽标 · 摘要 · 延时（与启动清单同一套仪表化列表）===== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ListPanel}">
                <DataGrid x:Name="Steps" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          HeadersVisibility="Column" SelectionMode="Single" MouseDoubleClick="SEdit_Click">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="24" CanUserResize="False" CellTemplate="{StaticResource RailCell}" CellStyle="{StaticResource RailCellStyle}"/>
                        <DataGridTemplateColumn Header="{loc:Loc Col_Kind}" Width="Auto" MinWidth="104">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource KindChipCell}">
                                        <TextBlock Text="{Binding KindLabel}" Style="{StaticResource KindChip}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{loc:Loc Col_Summary}" Binding="{Binding Summary}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="{loc:Loc Col_Delay}" Binding="{Binding DelayText}" Width="Auto" MinWidth="72"
                                            IsReadOnly="True" ElementStyle="{StaticResource DelayCol}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- 选中步骤的操作：编辑 / 删除 / 上移 / 下移（次级操作靠边，主操作「添加」在小标题旁）-->
            <StackPanel Grid.Column="1" Width="104" Margin="14,0,0,0">
                <Button Content="{loc:Loc Btn_Edit}" Margin="0,0,0,8" Click="SEdit_Click"/>
                <Button Content="{loc:Loc Btn_Delete}" Style="{StaticResource DangerButton}" Margin="0,0,0,8" Click="SDel_Click"/>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="{loc:Loc Btn_Up}" Padding="0,5" Margin="0,0,3,0" Click="SUp_Click"/>
                    <Button Grid.Column="1" Content="{loc:Loc Btn_Down}" Padding="0,5" Margin="3,0,0,0" Click="SDown_Click"/>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- ===== 确定 / 取消 ===== -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{loc:Loc Ed_Ok}" Style="{StaticResource PrimaryButton}" MinWidth="88" Height="34" Margin="0,0,10,0" Click="Ok_Click" IsDefault="True"/>
            <Button Content="{loc:Loc Ed_Cancel}" MinWidth="76" Height="34" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
